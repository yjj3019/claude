{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0"},
    "required_phrases": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string", "minLength": 1},
          {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "minItems": 1,
            "maxItems": 10,
            "uniqueItems": true
          }
        ]
      },
      "maxItems": 50
    },
    "forbidden_phrases": {"type": "array", "items": {"type": "string", "minLength": 1}, "maxItems": 50},
    "accepted_outputs": {"type": "array", "items": {"type": "string", "minLength": 1}, "maxItems": 20},
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maximum_output_lines": {"type": "integer", "minimum": 1},
        "maximum_output_characters": {"type": "integer", "minimum": 1},
        "maximum_tool_calls": {"type": "integer", "minimum": 0}
      }
    },
    "hard_failure_on": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["forbidden_phrase", "line_limit", "character_limit", "tool_limit"]}
    },
    "manual_review_on": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["required_phrase_missing", "accepted_output_mismatch", "tool_calls_unknown"]}
    }
  },
  "anyOf": [
    {"required": ["required_phrases"]},
    {"required": ["forbidden_phrases"]},
    {"required": ["accepted_outputs"]},
    {"required": ["constraints"]}
  ]
}
